{
  "name": "immanence",
  "version": "0.1.0",
  "description": "AI-powered codebase exploration utility with HTTP, CLI, and MCP interfaces.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iamkaf/immanence.git"
  },
  "bugs": {
    "url": "https://github.com/iamkaf/immanence/issues"
  },
  "homepage": "https://github.com/iamkaf/immanence#readme",
  "type": "module",
  "bin": {
    "immanence": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "dev": "tsx src/cli/index.ts",
    "lint": "oxlint . --ignore-pattern dist --ignore-pattern node_modules",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "serve:http": "tsx src/cli/index.ts serve http",
    "serve:mcp": "tsx src/cli/index.ts serve mcp",
    "test": "vitest run",
    "prepack": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@mariozechner/pi-ai": "^0.67.68",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^14.0.3",
    "fastify": "^5.8.5",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "oxlint": "^1.27.0",
    "oxfmt": "^0.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
